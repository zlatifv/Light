{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_WS_URL": "wss://light-backend.onrender.com/ws",
        "EXPO_PUBLIC_API_URL": "https://light-backend.onrender.com"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_WS_URL": "wss://light-backend.onrender.com/ws",
        "EXPO_PUBLIC_API_URL": "https://light-backend.onrender.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
