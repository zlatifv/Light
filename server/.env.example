# Copy to .env for local dev, or set in Render dashboard for production.

PORT=3001

# Must match the deployed web app's origin exactly (no trailing slash).
WEB_ORIGIN=http://localhost:5173

# Postgres connection string. Render Postgres gives you this directly —
# Render Dashboard > your Postgres instance > Connections > Internal/External URL
DATABASE_URL=postgresql://user:password@localhost:5432/light

# Random secret used to sign session JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NEVER reuse this across environments, never commit a real value.
JWT_SECRET=

# Optional — only needed for push-waking closed mobile apps (see mobile/ build).
# Paste the full Firebase service account JSON as a single-line string.
FIREBASE_SERVICE_ACCOUNT=

# OAuth credentials — one app per provider, created in each provider's
# developer console. Client IDs are also needed on the frontend (web/.env.example)
# but secrets stay here ONLY.

# console.cloud.google.com > APIs & Services > Credentials > OAuth client ID
# Authorized redirect URI: <your-web-app-url>/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# github.com/settings/developers > New OAuth App
# Authorization callback URL: <your-web-app-url>/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# discord.com/developers/applications > New Application > OAuth2
# Redirect: <your-web-app-url>/auth/callback/discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
