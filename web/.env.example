# Copy to .env.local for local dev, or set in Render dashboard for production.

# Signaling server WebSocket URL
VITE_WS_URL=ws://localhost:3001/ws

# REST API base URL (used once server/ grows beyond just signaling)
VITE_API_URL=http://localhost:3001

# OAuth client IDs — these are PUBLIC (safe in frontend code). The matching
# CLIENT SECRETS go on the server only (server/.env.example), never here.
VITE_GOOGLE_CLIENT_ID=
VITE_GITHUB_CLIENT_ID=
VITE_DISCORD_CLIENT_ID=
